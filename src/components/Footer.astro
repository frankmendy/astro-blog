---
const today = new Date();

const contactEmail = "frankmendy@gmail.com"; 
---

<footer>
	<p class="copyright">
		&copy; {today.getFullYear()} Alex | <strong>Gansu Odyssey</strong>. All rights reserved.
	</p>
	
	<div class="contact-box">
		<span class="contact-label">Business & Travel Inquiries:</span>
		<a href={`mailto:${contactEmail}`} class="email-link">
			<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px; vertical-align: -2px;"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
			{contactEmail}
		</a>
	</div>

	<div class="footer-links">
		<a href="/about">About Me</a>
		<span class="separator">•</span>
		<a href="/privacy-policy" style="opacity: 0.6;">Privacy Policy</a>
	</div>
</footer>

<style>
	footer {
		padding: 40px 20px;
		background-color: #ffffff;
		border-top: 1px solid #e2e8f0;
		text-align: center;
		font-family: sans-serif;
	}
	.copyright {
		margin: 0 0 16px 0;
		color: #475569;
		font-size: 0.95rem;
	}
	.contact-box {
		margin-bottom: 20px;
		background: #f8fafc;
		display: inline-block;
		padding: 10px 20px;
		border-radius: 9999px;
		border: 1px solid #f1f5f9;
	}
	.contact-label {
		font-size: 0.85rem;
		color: #64748b;
		margin-right: 8px;
		font-weight: 500;
	}
	.email-link {
		color: #b45309; /* 使用和你网站主色调一致的轻奢琥珀色 */
		text-decoration: none;
		font-weight: 600;
		font-size: 0.9rem;
		transition: color 0.2s ease;
	}
	.email-link:hover {
		color: #d97706;
		text-decoration: underline;
	}
	.footer-links {
		font-size: 0.85rem;
	}
	.footer-links a {
		color: #64748b;
		text-decoration: none;
	}
	.footer-links a:hover {
		color: #1e293b;
	}
	.separator {
		margin: 0 10px;
		color: #cbd5e1;
	}
</style>
