---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
// 导入 Astro 官方的核心图像优化组件（用来彻底消灭灰色方块）
import { Image } from 'astro:assets';

// 引入全局样式以防裸奔
import '../styles/global.css';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* 强制保底样式：哪怕全局样式崩了，这里的局部样式也绝对生效 */
			.travel-hero {
				background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('https://images.unsplash.com/photo-1542640244-7e672d6cef21?auto=format&fit=crop&w=1200&q=80');
				background-size: cover;
				background-position: center;
				color: white;
				padding: 80px 40px;
				border-radius: 16px;
				margin-bottom: 40px;
				font-family: sans-serif;
			}
			.travel-hero h1 { font-size: 3rem; margin: 10px 0; font-weight: 800; }
			.travel-hero p { font-size: 1.2rem; color: #e2e8f0; max-width: 600px; }
			.btn-explore {
				background-color: #f59e0b; color: #1e293b; padding: 12px 30px;
				border-radius: 9999px; text-decoration: none; font-weight: bold;
				display: inline-block; margin-top: 20px;
			}
			.photo-grid {
				display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
				gap: 30px; list-style: none; padding: 0;
			}
			.photo-card {
				background: white; border-radius: 12px; overflow: hidden;
				box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); border: 1px solid #f1f5f9;
				display: flex; flex-direction: column;
			}
			.card-img-box { width: 100%; aspect-ratio: 16/10; overflow: hidden; background: #e2e8f0; }
			/* 修正了之前的 hieght 拼写错误，强制让组件图片自适应完美裁剪 */
			.card-img-box img { width: 100%; height: 100%; object-fit: cover; display: block; }
			.card-content { padding: 24px; font-family: sans-serif; flex-grow: 1; }
			.card-content h3 { margin: 8px 0; font-size: 1.5rem; color: #0f172a; }
			.card-content h3 a { text-decoration: none; color: inherit; }
			.card-content h3 a:hover { color: #d97706; }
		</style>
	</head>
	<body style="background-color: #f8fafc; margin: 0; padding: 0;">
		<Header />
		
		<main style="max-width: 1200px; margin: 0 auto; padding: 40px 20px;">
			<section class="travel-hero">
				<span style="color: #fbbf24; font-weight: bold; tracking-wider; text-transform: uppercase; font-size: 0.85rem;">The Ultimate Silk Road Adventure</span>
				<h1>Discover Gansu Odyssey</h1>
				<p>Explore majestic sand dunes, rainbow mountains, and ancient Buddhist art through stunning visual stories.</p>
				<a href="#posts" class="btn-explore">Start Exploring</a>
			</section>

			<section id="posts">
				<h2 style="font-size: 2rem; font-weight: 800; margin-bottom: 24px; font-family: sans-serif;">Latest Photo Guides</h2>
				<ul class="photo-grid">
					{
						posts.map((post) => (
							<li class="photo-card">
								<div class="card-img-box">
									{/* 
									  核心改动：使用官方核心 Image 组件替代普通 img 标签。
									  它会吃下 post.data.heroImage 对象，并在打包时全自动生成带有 WebP 压缩的高清大图网址。
									*/}
									<Image src={post.data.heroImage} width={720} height={450} alt={post.data.title} />
								</div>
								<div class="card-content">
									{post.data.tags && (
										<span style="color: #eab308; font-size: 0.75rem; font-weight: bold; text-transform: uppercase; letter-spacing: 0.05em; display: block; margin-bottom: 0.25rem;">
											{post.data.tags[0]}
										</span>
									)}
									<h3><a href={`/blog/${post.id}/`}>{post.data.title}</a></h3>
									<span style="font-size: 0.75rem; color: #64748b; font-weight: 500; display: block; margin-bottom: 8px;"><FormattedDate date={post.data.pubDate} /></span>
									<p style="color: #475569; font-size: 0.95rem; line-height: 1.5; margin: 0;">{post.data.description}</p>
								</div>
							</li>
						))
					}
				</ul>
			</section>
		</main>

		<Footer />
	</body>
</html>
