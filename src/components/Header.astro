---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';


const contactEmail = "gsodyssey@gmail.com"; 
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		
		<!-- 右上角黄金位置：替换为极简、高级的联系按钮 -->
		<div class="action-zone">
			<a href={`mailto:${contactEmail}`} class="contact-btn">
				<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px; vertical-align: -1px;"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
				Contact Me
			</a>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: #0f172a;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1200px;
		margin: 0 auto;
		padding: 1em 0;
	}
	.internal-links {
		display: flex;
		gap: 1em;
	}
	nav a {
		padding: 0.5em 0.5em;
		color: #475569;
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: #b45309;
		color: #0f172a;
		font-weight: bold;
	}
	
	/* 新增的按钮精修样式 */
	.action-zone {
		display: flex;
		align-items: center;
	}
	.contact-btn {
		background-color: #f59e0b; /* 和首页 Start Exploring 一致的暖金主色，极度吸睛 */
		color: #1e293b !important;
		font-size: 0.85rem;
		font-weight: 700;
		padding: 6px 16px !important;
		border-radius: 9999px;
		border: none !important;
		transition: all 0.2s ease;
		display: inline-flex;
		align-items: center;
		box-shadow: 0 2px 4px rgba(245, 158, 11, 0.2);
	}
	.contact-btn:hover {
		background-color: #d97706;
		transform: translateY(-1px);
		box-shadow: 0 4px 6px rgba(217, 119, 6, 0.3);
	}
</style>
